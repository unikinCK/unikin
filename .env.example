# OpenAI-compatible local API
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=local-key
OPENAI_MODEL=local-model

# Agent identity/mission
UNIKIN_IDENTITY=Unikin
UNIKIN_MISSION=Kontinuierliche reflektierte Arbeit in kleinen Schritten mit robustem Selbstmonitoring.

# Adaptive interval bounds (seconds)
MIN_INTERVAL_SECONDS=5
MAX_INTERVAL_SECONDS=300
DEFAULT_INTERVAL_SECONDS=30

# Files
MEMORY_FILE=memory/unikin_state.json
LOG_FILE=logs/unikin.log
